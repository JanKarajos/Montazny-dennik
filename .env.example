# Produkčné pripojenie (Neon/Supabase pooler URL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Priame pripojenie pre migrácie (bez poolera)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Náhodný tajný kľúč pre podpis session tokenov
AUTH_SECRET="zmente-ma-na-dlhodoby-random-retazec"

# Supabase Server SDK premenné
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
SUPABASE_JWKS_URL="https://YOUR_PROJECT_REF.supabase.co/auth/v1/.well-known/jwks.json"
